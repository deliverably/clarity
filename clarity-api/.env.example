# Run `npm run setup:env` (or `cp .env.example .env`) to create `.env`.
# Compose and Node load `.env` from the `clarity-api/` folder — there is no committed `.env` in git.

# Server
PORT=3000
# CORS_ORIGIN=http://localhost:8080

# Optional: require this header on all /api/* routes
# CLARITY_API_KEY=your-shared-secret

# --- LLM ---
# Default when unset: Amazon Bedrock (set AWS credentials + model below).
# Override with: LLM_PROVIDER=gemini | openai | bedrock
LLM_PROVIDER=bedrock

# --- Amazon Bedrock (default) ---
# Uses standard AWS IAM access keys (NOT a separate “Bedrock API key” in this app).
# Turkish (IAM konsolu): Erişim anahtarı → AWS_ACCESS_KEY_ID
#                         Gizli erişim anahtarı → AWS_SECRET_ACCESS_KEY
# Do not wrap values in quotes. No spaces before/after =. Keys must belong to an IAM user/role
# with bedrock:InvokeModel (and model access enabled in Bedrock console for this region).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional session token (STS / temporary creds)
# AWS_SESSION_TOKEN=

# Model ID from Bedrock console (must be enabled in your account & region).
# Default below is Amazon Nova Micro — typically the cheapest Bedrock text model for testing (see AWS Bedrock pricing).
# For higher quality: e.g. anthropic.claude-3-5-haiku-20241022-v1:0 or anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_MODEL_ID=amazon.nova-micro-v1:0

# Optional overrides
# BEDROCK_REGION=us-east-1
# BEDROCK_ENDPOINT_URL=
# BEDROCK_MAX_TOKENS=8192
# BEDROCK_TEMPERATURE=0.2

# --- Google Gemini (only if LLM_PROVIDER=gemini) ---
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GOOGLE_API_KEY is also read when LLM_PROVIDER=gemini (not used alone to auto-pick Gemini when LLM_PROVIDER is unset — avoids clashes with other Google APIs).
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- OpenAI (only if LLM_PROVIDER=openai) ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
